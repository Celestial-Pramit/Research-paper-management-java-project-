<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="56" styleClass="topbar" alignment="CENTER_LEFT" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.researchpapers.controller.TopbarController">
    <VBox spacing="1" styleClass="topbar-brand-stack">
        <Label text="RESEARCH PAPER MANAGEMENT" styleClass="topbar-brand-primary" />
        <Label text="SYSTEM" styleClass="topbar-brand-secondary" />
    </VBox>
    <Region HBox.hgrow="ALWAYS" />
    <StackPane>
        <Button fx:id="btnNotification" text="🔔" styleClass="topbar-icon-btn" onAction="#notificationEvent" />
        <Region styleClass="notification-dot" StackPane.alignment="TOP_RIGHT" />
    </StackPane>
    <StackPane styleClass="user-avatar">
        <Label fx:id="lblAvatarInitials" text="JD" styleClass="avatar-text" />
    </StackPane>
    <VBox spacing="0" styleClass="user-info">
        <Label fx:id="lblUserName" text="John Doe" styleClass="user-name" />
        <Label fx:id="lblUserRole" text="USER" styleClass="user-role" />
    </VBox>
    <MenuButton fx:id="btnRoleDropdown" text="Switch Role" styleClass="role-dropdown">
        <items>
            <MenuItem text="USER" onAction="#switchToUser" />
            <MenuItem text="ADMIN" onAction="#switchToAdmin" />
        </items>
    </MenuButton>
</HBox>
